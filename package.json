{
  "name": "bpb-action-panel",
  "version": "1.0.0",
  "description": "A GitHub Actions-based panel inspired by BPB-Worker-Panel for educational and lulz purposes",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run build:panel",
    "build:panel": "node scripts/build-panel.js",
    "start": "node dist/index.js",
    "dead-code": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:swarm": "npx tsx tools/harness/index.ts smoke",
    "test:swarm:stress": "npx tsx tools/harness/index.ts stress",
    "agent": "npx tsx tools/logging/swarm-logger.ts",
    "agent:dht": "cd tools/sim && npx tsx dht-cluster-sim.ts",
    "agent:ghost": "cd tools/monitor && npx tsx ghost-detector.ts",
    "agent:bootstrap": "cd tools/bootstrap && npx tsx validate-bootstrap.ts",
    "agent:keyspace": "cd tools/debug && npx tsx keyspace-inspector.ts",
    "agent:tunnel-mock": "cd tools/mock && npx tsx tunnel-emitter.ts --provider trycloudflare",
    "agent:spec-check": "cd tools/spec && npx tsx validate-spec.ts",
    "ledger:demo": "cd tools/ci && npx tsx ci-pipeline.ts --ledger /tmp/swarm-ledger.jsonl --report /tmp/swarm-report.json",
    "ledger:check": "cd tools/ci && npx tsx ci-pipeline.ts --json-dir /tmp/swarm-results --ledger /tmp/swarm-ledger.jsonl",
    "lint": "biome lint .",
    "lint:complexity": "biome lint --only=complexity .",
    "format": "biome format . --write",
    "check": "biome check .",
    "prepare": "husky"
  },
  "keywords": [
    "github-actions",
    "panel",
    "devops",
    "ci-cd",
    "workflow",
    "dashboard"
  ],
  "author": "GitHub Actions Enthusiast",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@multiformats/multiaddr": "^13.0.3",
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "tsx": "^3.12.0",
    "typescript": "^5.1.6",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
